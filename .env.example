# Connection endpoints and secrets ONLY. Everything that affects results
# (model, sampling, prompt, paths) lives in config.yaml. Copy this file to .env
# and fill in real values. .env is gitignored -- never commit it.

# Workhorse endpoint (OpenAI-compatible). Examples:
#   Gemini: https://generativelanguage.googleapis.com/v1beta/openai/
#   Ollama: http://localhost:11434/v1
#   vLLM:   http://localhost:8000/v1
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_API_KEY=your-gemini-api-key-here

# Oracle endpoint -- label bootstrapping / ceiling benchmark only, never the main loop.
# ORACLE_BASE_URL=https://chat.maritaca.ai/api
# ORACLE_API_KEY=your-maritaca-key-here
